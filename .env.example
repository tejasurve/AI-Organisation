# Copy to `.env.local` (which is git-ignored) and fill in your own keys.
# All values are optional — the platform also lets you paste keys at runtime
# via Settings → Secrets, which persists them encrypted to
# `.simulation/secrets.json` (also git-ignored).

# Stitch MCP (Designer / Figma flow). If set, the value is seeded into the
# encrypted vault on first boot so Designer works out-of-the-box.
STITCH_API_KEY=

# Gemini (Google AI) — used by every persona LLM call. Required for the
# orchestration engine to do anything real.
GEMINI_API_KEY=

# Optional alternative providers — set if you intend to wire them in.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# CURSOR_API_KEY=

# Optional GitHub PAT — only required if you wire up the Developer's
# auto-PR / repo-create flow. Scope: repo.
# GITHUB_TOKEN=
