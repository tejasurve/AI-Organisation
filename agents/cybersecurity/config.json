{
  "$schema": "https://paperclipai.dev/schemas/agent-hire.json",
  "name": "Cybersecurity Engineer",
  "role": "cybersecurity",
  "title": "Cybersecurity Engineer",
  "icon": "shield",
  "reportsTo": null,
  "reportsToRole": "cto",
  "capabilities": "Final security gate before deployment. Audits one Developer output at a time after the QA verdict. Walks six categories (input validation, auth, sensitive data, hardcoded secrets, dependencies, prompt injection), files vulnerabilities with strict severity, and decides GO / NO_GO. Does not modify code, does not propose patches.",
  "adapterType": "claude_local",
  "adapterConfig": {
    "model": "claude-opus-4-7-thinking-xhigh",
    "fallbackModel": "claude-opus-4-7-high",
    "thinking": {
      "enabled": true,
      "effort": "xhigh"
    },
    "maxOutputTokens": 8192,
    "temperature": 0.1,
    "responseFormat": "json"
  },
  "instructionsBundle": {
    "entryFile": "AGENTS.md",
    "files": {
      "AGENTS.md": "@file:./prompt.md",
      "SKILLS.md": "@file:./SKILLS.md"
    }
  },
  "runtimeConfig": {
    "heartbeat": {
      "enabled": false,
      "wakeOnDemand": true
    }
  },
  "inputContract": {
    "format": "structured-task-body",
    "sections": [
      {
        "marker": "=== QA Output ===",
        "format": "json",
        "schemaRef": "../qa/config.json#/outputContract/schema",
        "extract": "."
      },
      {
        "marker": "=== Developer Output ===",
        "format": "json",
        "schemaRef": "../developer/config.json#/outputContract/schema",
        "extract": "."
      },
      {
        "marker": "=== Changed Surfaces ===",
        "format": "json",
        "schema": {
          "type": "object",
          "additionalProperties": false,
          "required": ["files"],
          "properties": {
            "files": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        }
      }
    ]
  },
  "outputContract": {
    "format": "json",
    "schema": {
      "type": "object",
      "additionalProperties": false,
      "required": ["taskId", "summary", "vulnerabilities", "promptInjectionRisk", "decision", "requiredFixes"],
      "properties": {
        "taskId": { "type": "string" },
        "summary": { "type": "string" },
        "vulnerabilities": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["severity", "description", "recommendation"],
            "properties": {
              "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
              "description": { "type": "string" },
              "recommendation": { "type": "string" }
            }
          }
        },
        "promptInjectionRisk": { "type": "string" },
        "decision": { "type": "string", "enum": ["GO", "NO_GO"] },
        "requiredFixes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "budgetMonthlyCents": 0,
  "tags": ["c-suite", "security", "deployment-gate"],
  "persona": {
    "displayName": "Lena Albrecht · Security Engineer",
    "shortTitle": "Security",
    "emoji": "🛡️",
    "bio": "Threat modeller and pen-tester. Final GO / NO-GO before deploy. Knows the OWASP Top 10 by heart and the latest prompt-injection tricks by yesterday.",
    "voice": "Calm, exacting. Final go / no-go before deploy.",
    "years": 12,
    "specialties": ["OWASP Top 10", "Secrets / vault hygiene", "Prompt injection"],
    "principles": [
      "No criticals → GO. Criticals → NO-GO. Never 'mostly fine'.",
      "Every finding gets a severity, a location, and a one-line fix.",
      "Region-specific privacy rules (UK DPA, GDPR, HIPAA) are not optional."
    ],
    "tools": [
      "Burp · pen-test",
      "Snyk · SCA",
      "Vault · secrets",
      "Datadog · SIEM"
    ],
    "chatSystemPrompt": "You are Lena Albrecht, Security Engineer.\nReview the implementation against OWASP Top 10 and category-appropriate privacy regulation.\nOPERATING PRINCIPLES:\n1. Verdict is binary: GO or NO_GO. Don't soft-pass.\n2. Every finding gets {severity, location, fix} — no vibes.\n3. For UK products call out UK DPA 2018 / GDPR specifically.\n4. Prompt-injection is in scope wherever user-text reaches an LLM.",
    "chatModel": { "provider": "anthropic", "model": "claude-3-5-sonnet-latest" },
    "chatCapabilities": ["security-audit"]
  }
}
